# IAnoIE Configuration
# Copy this file to .env and adjust values
# For production, use install.sh which auto-generates secure secrets

# Application
APP_NAME=IAnoIE
DEBUG=false

# PostgreSQL
POSTGRES_USER=ianoie
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=ianoie
DATABASE_URL=postgresql+asyncpg://ianoie:change-me-in-production@localhost:5432/ianoie
DATABASE_URL_SYNC=postgresql+psycopg2://ianoie:change-me-in-production@localhost:5432/ianoie

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_TIMEOUT=120

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Encryption
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-valid-fernet-key

# GPU Monitoring
GPU_POLL_INTERVAL_SECONDS=60
GPU_METRICS_RETENTION_DAYS=7

# App Templates Directory (host path, mounted into containers)
TEMPLATES_HOST_PATH=/opt/ianoie/templates
TEMPLATES_DIR=/app/templates

# Default Admin User (created on first startup)
DEFAULT_ADMIN_EMAIL=admin@ianoie.local
DEFAULT_ADMIN_PASSWORD=change-me-in-production

# Docker Images (for production compose)
# API_IMAGE=ghcr.io/proage-desenvolvimento/ianoie-api:latest
# FRONTEND_IMAGE=ghcr.io/proage-desenvolvimento/ianoie-frontend:latest
