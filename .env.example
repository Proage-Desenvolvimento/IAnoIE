# IAnoIE Configuration
# Copy this file to .env and adjust values

# Application
APP_NAME=IAnoIE
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://ianoie:ianoie@localhost:5432/ianoie
DATABASE_URL_SYNC=postgresql+psycopg2://ianoie:ianoie@localhost:5432/ianoie

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_TIMEOUT=120

# JWT Authentication
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-to-a-valid-fernet-key

# GPU Monitoring
GPU_POLL_INTERVAL_SECONDS=60
GPU_METRICS_RETENTION_DAYS=7

# App Templates Directory
TEMPLATES_DIR=/app/templates

# Default Admin User (created on first startup)
DEFAULT_ADMIN_EMAIL=admin@ianoie.local
DEFAULT_ADMIN_PASSWORD=admin
